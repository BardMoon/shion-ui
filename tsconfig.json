{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "types": ["svelte", "vite/client"],

    "strict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    "allowArbitraryExtensions": true,

    "allowJs": false,
    "checkJs": false,

    "noEmit": true,

    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"],
    },
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.d.ts",
    "src/**/*.svelte",
    "vite.config.ts",
  ],
}
